{
	"$schema": "./node_modules/@biomejs/biome/configuration_schema.json",
	"vcs": {
		"enabled": true,
		"clientKind": "git",
		"useIgnoreFile": true,
		"defaultBranch": "master",
	},
	"files": {
		"includes": ["**", "!!**/dist"],
	},
	"formatter": {
		"enabled": false, // dprint handles formatting
	},
	"linter": {
		"enabled": true,
		"rules": {
			"recommended": true,
		},
	},
	"assist": {
		"enabled": true,
		"actions": {
			"source": {
				"organizeImports": "off",
			},
		},
	},
}
