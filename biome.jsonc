{
	"$schema": "https://biomejs.dev/schemas/2.4.4/schema.json",
	"vcs": {
		"enabled": true,
		"clientKind": "git",
		"useIgnoreFile": true,
	},
	"files": {
		"includes": ["**", "!!**/dist"],
	},
	"formatter": {
		"enabled": false, // dprint handles formatting
	},
	"linter": {
		"enabled": true,
		"rules": {
			"recommended": true,
		},
	},
	"assist": {
		"enabled": true,
		"actions": {
			"source": {
				"organizeImports": "on",
			},
		},
	},
}
