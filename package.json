{
  "name": "vite-robots-txt",
  "version": "0.1.0",
  "description": "Vite plugin to generate robots.txt with presets, per-bot rules, and dev mode blocking",
  "keywords": [
    "vite",
    "vite-plugin",
    "robots.txt",
    "robots",
    "seo",
    "crawlers",
    "ai-crawlers"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/kjanat/vite-robots-txt"
  },
  "license": "MIT",
  "author": "Kaj Kowalski",
  "type": "module",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "main": "dist/index.cjs",
  "module": "dist/index.mjs",
  "types": "dist/index.d.mts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown",
    "build:pkg": "tsdown",
    "dev": "tsdown --watch",
    "fmt": "dprint fmt",
    "lint": "biome check src/",
    "tar": "TARBALL=$(bun pm pack --quiet | tr -d '\\n'); echo \"tar=${TARBALL}\" >> ${GITHUB_OUTPUT:-/dev/stdout}",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.4",
    "@types/node": "^25.3.3",
    "dprint": "^0.52.0",
    "tsdown": "^0.21.0-beta.2",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vitest": "^4.0.18"
  },
  "peerDependencies": {
    "vite": "^5.0.0 || ^6.0.0 || ^7.0.0"
  }
}
